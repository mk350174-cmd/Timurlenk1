# ─────────────────────────────────────────────────────────────
# Timurlenk Satranç Online — Environment Variables
# Copy this file to `.env.local` and fill in your Supabase project values.
# The app runs fully in LOCAL/OFFLINE mode if these are left empty.
# ─────────────────────────────────────────────────────────────

# Supabase project URL, e.g. https://abcdefgh.supabase.co
VITE_SUPABASE_URL=

# Supabase public anon key (safe to expose to the browser)
VITE_SUPABASE_ANON_KEY=

# Optional: Socket.io fallback server URL (leave empty to disable Socket.io fallback)
VITE_SOCKET_URL=
